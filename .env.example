# Direct database credentials for source refresh.
# Do not commit a real .env file.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=gainr_source
MYSQL_USER=
MYSQL_PASSWORD=

# Optional destination database for storing final embedding-ready output.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=rag_ht
POSTGRES_USER=
POSTGRES_PASSWORD=

# Every additional company should use its own namespaced variables and env file.
# Example for configs/companies/example-flat.yaml.example:
ACME_MYSQL_HOST=localhost
ACME_MYSQL_PORT=3306
ACME_MYSQL_DATABASE=acme_catalog
ACME_MYSQL_USER=
ACME_MYSQL_PASSWORD=

# Example company-specific PostgreSQL source connection.
ACME_SOURCE_POSTGRES_HOST=localhost
ACME_SOURCE_POSTGRES_PORT=5432
ACME_SOURCE_POSTGRES_DATABASE=acme_source
ACME_SOURCE_POSTGRES_USER=
ACME_SOURCE_POSTGRES_PASSWORD=
