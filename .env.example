# Read-only credentials used only for source refresh SELECT queries.
# Grant SELECT only to this account. Do not commit a real .env file.
SOURCE_MYSQL_HOST=localhost
SOURCE_MYSQL_PORT=3306
SOURCE_MYSQL_DATABASE=gainr_source
SOURCE_MYSQL_USER=
SOURCE_MYSQL_PASSWORD=

# Separate writer credentials used only for atomic destination publishing.
DEST_MYSQL_HOST=localhost
DEST_MYSQL_PORT=3306
DEST_MYSQL_DATABASE=gainr_destination
DEST_MYSQL_USER=
DEST_MYSQL_PASSWORD=

# Optional destination database for storing final embedding-ready output.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=rag_ht
POSTGRES_USER=
POSTGRES_PASSWORD=

# Optional alerts. Supports a generic JSON webhook and local sendmail.
RAG_HT_ALERT_WEBHOOK_URL=
RAG_HT_ALERT_EMAIL=

# Every additional company should use its own namespaced variables and env file.
# Example for configs/companies/example-flat.yaml.example:
ACME_MYSQL_HOST=localhost
ACME_MYSQL_PORT=3306
ACME_MYSQL_DATABASE=acme_catalog
ACME_MYSQL_USER=
ACME_MYSQL_PASSWORD=

# Example company-specific PostgreSQL source connection.
ACME_SOURCE_POSTGRES_HOST=localhost
ACME_SOURCE_POSTGRES_PORT=5432
ACME_SOURCE_POSTGRES_DATABASE=acme_source
ACME_SOURCE_POSTGRES_USER=
ACME_SOURCE_POSTGRES_PASSWORD=
